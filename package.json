{
  "name": "al-dine",
  "version": "1.0.0",
  "private": true,
  "description": "AL DINE Islamic app (web, Capacitor, Electron, PWA)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "cap:init": "npx cap init \"AL DINE\" com.aldine.app --web-dir=.",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
